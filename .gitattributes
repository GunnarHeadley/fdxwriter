# Normalize line endings on commit; check out native on each platform.
* text=auto

# Unix shell scripts must stay LF (Gradle wrapper).
*.sh    text eol=lf
gradlew text eol=lf

# Windows scripts stay CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat binary assets as binary.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.webp    binary
*.gif     binary
*.jar     binary
*.keystore binary
*.fdx     binary
